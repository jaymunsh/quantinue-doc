# Quantinue local MVP configuration (contains no real secrets)
# 1) cp .env.example .env
# 2) Keep .env untracked. Put provider keys only in .env or your shell/secret manager.
# 3) Defaults are offline: no network LLM, no broker request, no trading side effect.

QUANTINUE_DEBUG=true

# fixture: deterministic offline market data (default)
# public: no-key NASDAQ/Stooq/FRED/SEC/RSS adapters with real HTTP calls
QUANTINUE_DATA_MODE=fixture

# memory: easiest local run, no database required
# postgres: use with Docker Compose. Host access is deliberately 5444; never change
# this project to localhost:5432. Containers use the service DNS name db:5432.
QUANTINUE_DATABASE_MODE=memory
# Local uv process + Compose database:
QUANTINUE_DATABASE_URL=postgresql+asyncpg://quantinue:quantinue@127.0.0.1:5444/quantinue
# Inside Compose, compose.yaml overrides this with:
# postgresql+asyncpg://quantinue:quantinue@db:5432/quantinue

# Safe default. Uses deterministic fixture results and never calls a network model.
QUANTINUE_LLM_MODE=mock
# Mock도 YAML 기본 모델 식별자를 사용하며, 필요하면 계보 표기만 덮어쓸 수 있습니다.
QUANTINUE_MOCK_MODEL=deterministic-mock-v1

# OpenAI mode (optional, billable network calls). Set the key in .env, never here.
# QUANTINUE_LLM_MODE=openai
QUANTINUE_OPENAI_API_KEY=
QUANTINUE_OPENAI_MODEL=gpt-4o-mini
# Shared request timeout. 90 seconds is recommended for local 35B-class models.
QUANTINUE_LLM_TIMEOUT_SECONDS=90
QUANTINUE_LLM_MAX_RETRIES=1

# Local LLM mode. Any OpenAI-compatible /v1 server can be used.
# Ollama example: `ollama serve`, then `ollama pull qwen2.5:7b`.
# Local uv run: http://127.0.0.1:11434/v1
# Docker Desktop: http://host.docker.internal:11434/v1
# LM Studio commonly uses http://127.0.0.1:1234/v1 (Docker: host.docker.internal).
# QUANTINUE_LLM_MODE=local
QUANTINUE_LOCAL_LLM_BASE_URL=http://127.0.0.1:11434/v1
QUANTINUE_LOCAL_LLM_API_KEY=local-not-secret
QUANTINUE_LOCAL_LLM_MODEL=qwen2.5:7b

# Alpaca PAPER only. Live endpoint and live credentials are rejected by configuration.
# Create paper credentials at Alpaca, copy them only into your untracked .env, and read
# docs/REAL_KEY_TESTING.md before opting in. Tests skip real-key cases by default.
QUANTINUE_BROKER_MODE=mock
QUANTINUE_ALPACA_API_KEY=
QUANTINUE_ALPACA_SECRET_KEY=
QUANTINUE_ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Second safety lock. Both BROKER_MODE=alpaca and TRADING_ENABLED=true are required.
# Enabling can submit/cancel paper orders. It must never be used with a live account.
QUANTINUE_TRADING_ENABLED=false
# Required only when paper trading is enabled. Store a user-provided value in your untracked .env.
QUANTINUE_CONTROL_ROOM_TOKEN=

# App-managed planned buy-order exposure, not broker cash, portfolio value, or fill cost.
QUANTINUE_MAX_APP_ORDER_EXPOSURE_USD=1000.00
# First-cycle guardrail: maximum newly submitted orders per account per UTC day.
QUANTINUE_DAILY_NEW_ORDER_CAP=1
